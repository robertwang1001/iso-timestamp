{
  "name": "iso-timestamp",
  "type": "module",
  "version": "2.0.0",
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485",
  "description": "Generate ISO 8601 timestamp: YYYYMMDDhhmmssSSS",
  "author": {
    "name": "Robert Wang",
    "email": "glorywong1001@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/robertwang1001/iso-timestamp#readme",
  "repository": "github:robertwang1001/iso-timestamp",
  "bugs": "https://github.com/robertwang1001/iso-timestamp/issues",
  "keywords": [
    "timestamp",
    "datetime",
    "date",
    "time",
    "format",
    "generator",
    "utility",
    "typescript",
    "javascript",
    "iso8601",
    "chrono",
    "time-stamp"
  ],
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.d.ts",
    "index.js"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm test && pnpm build",
    "prepare": "pnpm simple-git-hooks",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "test": "vitest run",
    "coverage": "vitest run --coverage.enabled"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.13.0",
    "@vitest/coverage-istanbul": "^4.1.8",
    "eslint": "^10.4.1",
    "lint-staged": "^17.0.7",
    "simple-git-hooks": "^2.13.1",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm commitlint --edit ${1}",
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "pnpm lint:fix"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
