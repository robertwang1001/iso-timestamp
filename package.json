{
  "name": "iso-timestamp",
  "type": "module",
  "version": "2.0.0",
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "description": "Generate ISO 8601 timestamp: YYYYMMDDhhmmssSSS",
  "author": {
    "name": "Robert Wang",
    "email": "glorywong1001@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/robertwang1001/iso-timestamp#readme",
  "repository": "github:robertwang1001/iso-timestamp",
  "bugs": "https://github.com/robertwang1001/iso-timestamp/issues",
  "keywords": [
    "timestamp",
    "datetime",
    "date",
    "time",
    "format",
    "generator",
    "utility",
    "typescript",
    "javascript",
    "iso8601",
    "chrono",
    "time-stamp"
  ],
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.d.ts",
    "index.js"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm test && pnpm build",
    "prepare": "pnpm simple-git-hooks",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "test": "vitest run",
    "coverage": "vitest run --coverage.enabled"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.0.0",
    "@commitlint/cli": "^21.0.2",
    "@commitlint/config-conventional": "^21.0.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.13.2",
    "@vitest/coverage-istanbul": "^4.1.9",
    "eslint": "^10.5.0",
    "lint-staged": "^17.0.7",
    "simple-git-hooks": "^2.13.1",
    "type-fest": "^5.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm commitlint --edit ${1}",
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "pnpm lint:fix"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
