{
  "name": "iso-timestamp",
  "type": "module",
  "version": "2.0.0",
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882",
  "description": "Generate ISO 8601 timestamp: YYYYMMDDhhmmssSSS",
  "author": {
    "name": "Robert Wang",
    "email": "glorywong1001@gmail.com"
  },
  "license": "MIT",
  "homepage": "https://github.com/robertwang1001/iso-timestamp#readme",
  "repository": "github:robertwang1001/iso-timestamp",
  "bugs": "https://github.com/robertwang1001/iso-timestamp/issues",
  "keywords": [
    "timestamp",
    "datetime",
    "date",
    "time",
    "format",
    "generator",
    "utility",
    "typescript",
    "javascript",
    "iso8601",
    "chrono",
    "time-stamp"
  ],
  "main": "index.js",
  "types": "index.d.ts",
  "files": [
    "index.d.ts",
    "index.js"
  ],
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "pnpm test && pnpm build",
    "prepare": "pnpm simple-git-hooks",
    "lint": "eslint .",
    "lint:fix": "pnpm lint --fix",
    "test": "vitest run",
    "coverage": "vitest run --coverage.enabled"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.2.0",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.13.3",
    "@vitest/coverage-istanbul": "^4.1.10",
    "eslint": "^10.6.0",
    "lint-staged": "^17.0.8",
    "simple-git-hooks": "^2.13.1",
    "type-fest": "^5.8.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "simple-git-hooks": {
    "commit-msg": "pnpm commitlint --edit ${1}",
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "pnpm lint:fix"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
